---
---
<!-- Call to Action Banner -->
<div class="bg-black border-b border-zinc-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="flex flex-col md:flex-row items-center justify-between gap-8">
            <div class="text-center md:text-left">
                <p class="text-[#7a7a7a] font-normal text-xs mb-2">Nhận mẫu dùng thử cho khách hàng tại quán của bạn!</p>
                <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight">Đăng ký làm Đại Lý Phân Phối Bia<br>ngay hôm nay.</h2>
            </div>
            <a href="tel:0963447890" class="flex-shrink-0 inline-flex items-center justify-center px-10 py-4 bg-[#ffcc00] hover:bg-[#e6b800] text-white font-bold rounded-[30px] transition-all duration-300 uppercase tracking-widest text-sm hover:-translate-y-1">
                Liên Hệ Ngay
            </a>
        </div>
    </div>
</div>

<!-- Main Footer -->
<footer class="bg-black text-gray-400 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
            
            <!-- Col 1: Sản Phẩm -->
            <div>
                <h3 class="text-white font-bold text-base mb-6">
                    Sản Phẩm
                </h3>
                <ul class="space-y-3">
                    <li><a href="/san-pham/bia-tuoi/" class="text-[#7a7a7a] hover:text-white transition-colors flex items-center gap-3"><i class="fas fa-chevron-right text-[10px]"></i> Bia Tươi</a></li>
                    <li><a href="/san-pham/bia-thap/" class="text-[#7a7a7a] hover:text-white transition-colors flex items-center gap-3"><i class="fas fa-chevron-right text-[10px]"></i> Bia Tháp</a></li>
                    <li><a href="/san-pham/bia-inox/" class="text-[#7a7a7a] hover:text-white transition-colors flex items-center gap-3"><i class="fas fa-chevron-right text-[10px]"></i> Bia Inox</a></li>
                    <li><a href="/san-pham/thiet-bi/" class="text-[#7a7a7a] hover:text-white transition-colors flex items-center gap-3"><i class="fas fa-chevron-right text-[10px]"></i> Thiết Bị</a></li>
                </ul>
            </div>

            <!-- Col 2: Chính sách -->
            <div>
                <h3 class="text-white font-bold text-base mb-6">
                    Chính sách
                </h3>
                <ul class="space-y-3">
                    <li><a href="/chinh-sach-bao-mat/" class="text-[#7a7a7a] hover:text-white transition-colors flex items-center gap-3"><i class="fas fa-chevron-right text-[10px]"></i> Chính sách bảo mật</a></li>
                </ul>
            </div>

            <!-- Col 3: Về chúng tôi -->
            <div>
                <h3 class="text-white font-bold text-base mb-6">
                    Về chúng tôi
                </h3>
                <ul class="space-y-3 mb-8">
                    <li><a href="/danh-gia-khach-hang/" class="text-[#7a7a7a] hover:text-white transition-colors flex items-center gap-3"><i class="fas fa-chevron-right text-[10px]"></i> Giới Thiệu</a></li>
                    <li><a href="/blog/" class="text-[#7a7a7a] hover:text-white transition-colors flex items-center gap-3"><i class="fas fa-chevron-right text-[10px]"></i> Blogs</a></li>
                </ul>
                <a href="//www.dmca.com/Protection/Status.aspx?ID=b7e20c6f-efa2-4d27-810f-65e50c540c7a" title="DMCA.com Protection Status" class="inline-block opacity-80 hover:opacity-100 transition-opacity">
                    <img src="https://images.dmca.com/Badges/dmca_protected_1_120.png?ID=b7e20c6f-efa2-4d27-810f-65e50c540c7a" alt="DMCA.com Protection Status" class="h-8">
                </a>
            </div>

            <!-- Col 4: Liên Hệ -->
            <div>
                <h3 class="text-white font-bold text-base mb-6">
                    Liên Hệ
                </h3>
                <div class="space-y-3 text-sm font-light leading-relaxed mb-6 text-[#7a7a7a]">
                    <p class="font-normal uppercase text-[13px] tracking-wide mb-4">Hệ Thống Bia Tháp – Bia Tươi – Bia Inox</p>
                    <p>An Phú, Thuận An, Bình Dương</p>
                    <p><a href="tel:0963447890" class="hover:text-white transition-colors">0963 447 890</a></p>
                    <p><a href="mailto:hethongbiathap@gmail.com" class="hover:text-white transition-colors">hethongbiathap@gmail.com</a></p>
                </div>
            </div>

        </div>

        <!-- Bottom Bar -->
        <div class="mt-20 pt-8 border-t border-zinc-800/50 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
            <p>© {new Date().getFullYear()} Hệ Thống Bia Tháp Vina Sài Gòn. All rights reserved.</p>
            <div class="flex items-center gap-4">
                <a href="https://www.facebook.com/hethongbiathap" target="_blank" class="w-10 h-10 rounded-full bg-zinc-900 flex items-center justify-center text-zinc-400 hover:bg-[#1877F2] hover:text-white transition-all duration-300">
                    <i class="fab fa-facebook-f"></i>
                </a>
            </div>
        </div>
    </div>
</footer>

<!-- ============================================== -->
<!-- DESKTOP Floating Contact Buttons -->
<!-- ============================================== -->
<div class="hidden md:block fixed z-[100] bg-white right-3 bottom-1/3 rounded-lg border border-zinc-200 shadow-lg py-4 px-2">
    <ul class="m-0 p-0 list-none">
        <!-- Chỉ đường -->
        <li class="mb-[14px] text-center w-full">
            <a href="https://goo.gl/maps/r7Ud7qBJoEAAtiKJ6" rel="nofollow" target="_blank" class="block py-0.5 group">
                <img src="https://media.hethongbiatuoi.com/google-maps.webp" alt="Chỉ đường" class="w-[28px] h-[28px] mx-auto object-contain transition-transform group-hover:scale-110" />
                <span class="block text-[10px] font-medium text-zinc-600 leading-tight mt-1 whitespace-nowrap">Chỉ đường</span>
            </a>
        </li>
        <!-- Zalo -->
        <li class="mb-[14px] text-center w-full">
            <a href="https://zalo.me/0963447890" rel="nofollow" target="_blank" class="block py-0.5 group">
                <img src="https://media.hethongbiatuoi.com/zalo.webp" alt="Zalo" class="w-[28px] h-[28px] mx-auto object-contain transition-transform group-hover:scale-110" />
                <span class="block text-[10px] font-medium text-zinc-600 leading-tight mt-1 whitespace-nowrap">Chat Zalo</span>
            </a>
        </li>
        <!-- Messenger -->
        <li class="text-center w-full">
            <a href="https://m.me/hethongbiathap" rel="nofollow" target="_blank" class="block py-0.5 group">
                <img src="https://media.hethongbiatuoi.com/messenger.webp" alt="Messenger" class="w-[28px] h-[28px] mx-auto object-contain transition-transform group-hover:scale-110" />
                <span class="block text-[10px] font-medium text-zinc-600 leading-tight mt-1 whitespace-nowrap">Messenger</span>
            </a>
        </li>
    </ul>
</div>

<!-- ============================================== -->
<!-- MOBILE Floating Contact Buttons -->
<!-- ============================================== -->
<div class="md:hidden fixed z-[100] bg-white bottom-0 left-0 w-full h-[60px] shadow-[0_-4px_10px_rgba(0,0,0,0.1)] px-1">
    <ul class="flex w-full h-full items-center justify-around m-0 p-0 list-none">
        <!-- 1. Chỉ đường -->
        <li class="w-1/5 flex justify-center">
            <a href="https://goo.gl/maps/r7Ud7qBJoEAAtiKJ6" rel="nofollow" target="_blank" class="flex flex-col items-center gap-0.5 group">
                <img src="https://media.hethongbiatuoi.com/google-maps.webp" alt="Chỉ đường" class="w-[34px] h-[34px] object-contain transition-transform group-hover:scale-110" />
                <span class="text-[11px] font-bold text-zinc-700 leading-tight whitespace-nowrap">Chỉ đường</span>
            </a>
        </li>
        <!-- 2. Zalo -->
        <li class="w-1/5 flex justify-center">
            <a href="https://zalo.me/0963447890" rel="nofollow" target="_blank" class="flex flex-col items-center gap-0.5 group">
                <img src="https://media.hethongbiatuoi.com/zalo.webp" alt="Zalo" class="w-[34px] h-[34px] object-contain transition-transform group-hover:scale-110" />
                <span class="text-[11px] font-bold text-zinc-700 leading-tight whitespace-nowrap">Chat Zalo</span>
            </a>
        </li>
        <!-- 3. Gọi điện (Large Green Popup) -->
        <li class="w-1/5 flex justify-center">
            <a href="tel:0963447890" rel="nofollow" class="flex flex-col items-center gap-1 group">
                <div class="w-[60px] h-[60px] bg-[#4CAF50] rounded-full border-[2px] border-white shadow-[0_4px_10px_rgba(0,0,0,0.2)] flex items-center justify-center -mt-[24px]">
                    <img src="https://media.hethongbiatuoi.com/p2.gif" alt="Gọi điện" class="w-[40px] h-[40px] object-contain" />
                </div>
                <span class="text-[11px] font-bold text-zinc-700 leading-tight whitespace-nowrap">Gọi điện</span>
            </a>
        </li>
        <!-- 4. Messenger -->
        <li class="w-1/5 flex justify-center">
            <a href="https://m.me/hethongbiathap" rel="nofollow" target="_blank" class="flex flex-col items-center gap-0.5 group">
                <img src="https://media.hethongbiatuoi.com/messenger.webp" alt="Messenger" class="w-[34px] h-[34px] object-contain transition-transform group-hover:scale-110" />
                <span class="text-[11px] font-bold text-zinc-700 leading-tight whitespace-nowrap">Messenger</span>
            </a>
        </li>
        <!-- 5. Nhắn tin SMS -->
        <li class="w-1/5 flex justify-center">
            <a href="sms:+84963447890" class="flex flex-col items-center gap-0.5 group">
                <img src="https://media.hethongbiatuoi.com/icon-sms-1.webp" alt="SMS" class="w-[34px] h-[34px] object-contain rounded transition-transform group-hover:scale-110" />
                <span class="text-[11px] font-bold text-zinc-700 leading-tight whitespace-nowrap">Nhắn tin SMS</span>
            </a>
        </li>
    </ul>
</div>

<style>
    .animate-pulse-slow {
        animation: pulse-slow 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @keyframes pulse-slow {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.7);
        }
        50% {
            box-shadow: 0 0 0 15px rgba(220, 38, 38, 0);
        }
    }

    /* === Force footer colors over Elementor global CSS === */
    /* Banner heading */
    h2 {
        color: #ffffff !important;
    }
    /* Banner subtitle */
    div > p:first-child {
        color: #7a7a7a !important;
    }
    /* Yellow CTA button */
    a[href="tel:0963447890"].flex-shrink-0 {
        background-color: #ffcc00 !important;
        color: #ffffff !important;
    }
    /* Section headings */
    h3 {
        color: #ffffff !important;
    }
    /* All footer links - gray, not orange */
    footer a {
        color: #7a7a7a !important;
    }
    footer a:hover {
        color: #ffffff !important;
    }
    /* Contact info text */
    footer div.space-y-3 p {
        color: #7a7a7a !important;
    }
    /* Bottom bar text */
    footer div.mt-20 p {
        color: #9ca3af !important;
    }
    /* Facebook icon */
    footer a[href*="facebook"] {
        color: #a1a1aa !important;
    }
    footer a[href*="facebook"]:hover {
        color: #ffffff !important;
    }
</style>