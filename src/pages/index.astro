                        </a>
                        <div class="p-6 text-center flex flex-col flex-grow">
                            <h3 class="text-xl font-bold text-yellow-600 mb-4 line-clamp-2 min-h-[3.5rem] leading-snug group-hover:text-brand-600 transition-colors" set:html={p.title}></h3>
