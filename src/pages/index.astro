---
import Layout from '../layouts/NativeLayout.astro';
import { env } from 'cloudflare:workers';

export const prerender = false;

let products = [];
try {
    const db = (env as any)?.DB || (env as any)?.hethongbiatuoi_db;
    if (db) {
        // Helper to remove WordPress thumbnail dimension suffixes to prevent 404s
        const stripWpSuffixes = (str: string) => {
            if (!str) return str;
            return str.replace(/-\d+x\d+\.(jpg|jpeg|png|webp|gif)/gi, '.$1');
        };

        // Fetch latest 9 products with images
        const { results } = await db.prepare(`
            SELECT p.id, p.title, p.slug, m.url as imageUrl 
            FROM Product p
            LEFT JOIN Media m ON p.featuredImage = m.id
            WHERE p.slug IN (
                'bia-ben-thanh-sai-gon-ong-gia',
                'bia-ben-thanh-sai-gon-do',
                'bia-ben-thanh-sai-gon-xanh',
                'bia-thap-3-lit',
                'bia-hemsi-sai-gon',
                'bia-naviken',
                'bia-vina-sai-gon-ho-lo',
                'bia-vina-sai-gon-400ml-xanh',
                'bia-vina-sai-gon-den'
            )
        `).all();
        
        products = (results || []).map((p: any) => {
            if (p.imageUrl) {
                p.imageUrl = p.imageUrl.replace(/(?:https?:\/\/(?:www\.)?hethongbiatuoi\.com)?\/wp-content\/uploads\/(?:\d{4}\/\d{2}\/)?/gi, 'https://media.hethongbiatuoi.com/');
                p.imageUrl = p.imageUrl.replace(/^\/uploads\//gi, 'https://media.hethongbiatuoi.com/');
                p.imageUrl = stripWpSuffixes(p.imageUrl);
            }
            return p;
        });
        
        const order = [
            'bia-ben-thanh-sai-gon-ong-gia',
            'bia-ben-thanh-sai-gon-do',
            'bia-ben-thanh-sai-gon-xanh',
            'bia-thap-3-lit',
            'bia-hemsi-sai-gon',
            'bia-naviken',
            'bia-vina-sai-gon-ho-lo',
            'bia-vina-sai-gon-400ml-xanh',
            'bia-vina-sai-gon-den'
        ];
        products.sort((a: any, b: any) => order.indexOf(a.slug) - order.indexOf(b.slug));
    }
} catch (e) {
    console.log("DB Error:", e);
}

const realImages = [
    "nhan-vien-he-thong-bia-thap-chup-hinh-cung-nguoi-dan.jpg",
    "chup-hinh-truoc-quan-nhau-bia-tuoi.jpg",
    "he-thong-bia-thap-di-den-cac-quan-an-tren-khap-noi.jpg",
    "he-thong-bia-thap-ban-giao-bia-cho-tiem-tap-hoa.jpg",
    "he-thong-bia-thap-giao-bia-cho-quan-nuong.jpg",
    "he-thong-bia-thap-di-den-cac-vung-tay-nguyen-vung-cao.jpg",
    "boc-do-bia-tuoi.jpg",
    "khong-gian-ben-trong-tu-lanh-he-thong-bia-thap.jpg",
    "san-pham-bia-tuoi-tren-ban-nhau.jpg",
    "ban-giao-tu-lanh-chuyen-dung-cho-khach-hang.jpg",
    "bia-inox-cua-he-thtoosng-bia-thap.jpg",
    "cac-loai-san-pham-bia-khac-nhau-cua-he-thong-bia-thap.jpg",
    "chuan-bi-giao-bia-cho-khach-hang.jpg",
    "giao-bia-va-ban-hieu-cho-tiem-an-le-duong.jpg",
    "he-thong-bia-thap-giao-hang-tren-moi-neo-duong.jpg"
];

// Ensure products fallback if DB empty (from original UI)
if (products.length === 0) {
    products = [
        { title: "Bia Bến Thành Sài Gòn Ông Già 900ml", slug: "bia-ben-thanh-sai-gon-ong-gia-900ml", imageUrl: "https://media.hethongbiatuoi.com/Ben-Thanh-SG-900ml-Ong-Gia-nen-vang.webp" },
        { title: "Bia Bến Thành Sài Gòn đỏ 900ml", slug: "bia-ben-thanh-sai-gon-do-900ml", imageUrl: "https://media.hethongbiatuoi.com/ben-thanh-sai-gon-do-900ml-nen-vang.webp" },
        { title: "Bia Bến Thành Sài Gòn xanh 500ml", slug: "bia-ben-thanh-sai-gon-xanh-500ml", imageUrl: "https://media.hethongbiatuoi.com/ben-thanh-sai-gon-500ml-xanh-nen-vang.webp" },
        { title: "Bia Tháp 3 Lít", slug: "bia-thap-3-lit", imageUrl: "https://media.hethongbiatuoi.com/Bia-Thap-3L-nen-vang.webp" },
        { title: "Bia Hemsi Sài Gòn 900ml", slug: "bia-hemsi-sai-gon-900ml", imageUrl: "https://media.hethongbiatuoi.com/Bia-Hemsi-Sai-Gon-900ml-nen-vang.webp" },
        { title: "Bia Naviken 900ml", slug: "bia-naviken-900ml", imageUrl: "https://media.hethongbiatuoi.com/Naviken-900ml-nen-vang.webp" },
        { title: "Bia Vina Sài Gòn hồ lô 500ml", slug: "bia-vina-sai-gon-ho-lo-500ml", imageUrl: "https://media.hethongbiatuoi.com/Vina-SG-500ml-Ho-Lo-nen-vang.webp" },
        { title: "Bia Vina Sài Gòn Xanh 400ml", slug: "bia-vina-sai-gon-xanh-400ml", imageUrl: "https://media.hethongbiatuoi.com/Vina-SG-500ml-xanh-nen-vang.webp" },
        { title: "Bia Vina Sài Gòn Đen 900ml", slug: "bia-vina-sai-gon-den-900ml", imageUrl: "https://media.hethongbiatuoi.com/Vina-SG-900ml-Den-nen-vang.webp" },
    ];
}

const extractVolume = (title: string) => {
    const match = title.match(/(\d+ml|\d+\s*Lít)/i);
    return match ? `bia ${match[1].toLowerCase()}` : '';
};
