---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';

export const prerender = false;

const search = Astro.url.searchParams.get('s') || '';
const pageParam = parseInt(Astro.url.searchParams.get('page') || '1');
const page = isNaN(pageParam) || pageParam < 1 ? 1 : pageParam;
const perPage = 20;
const offset = (page - 1) * perPage;

let posts: any[] = [];
let total = 0;

const db = (env as any)?.DB || (env as any)?.hethongbiatuoi_db;
if (db) {
    try {
        let query = `SELECT id, title, slug, createdAt FROM Post WHERE 1=1`;
        const params: any[] = [];

        if (search) {
            query += ` AND title LIKE ?`;
            params.push(`%${search}%`);
        }

        const countResult = await db.prepare(`SELECT count(*) as count FROM (${query})`).bind(...params).first();
        total = countResult?.count || 0;

        query += ` ORDER BY createdAt DESC LIMIT ? OFFSET ?`;
        params.push(perPage, offset);

        const { results } = await db.prepare(query).bind(...params).all();
        posts = results || [];
    } catch (e) {
        console.error("Posts DB Error:", e);
    }
}

const totalPages = Math.ceil(total / perPage);
---

<AdminLayout title="Quản lý Bài Viết">
    <div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Quản lý Bài Viết</h1>
            <p class="text-sm text-gray-500 mt-1">Tổng cộng {total} mục</p>
        </div>
        <div class="flex gap-2">
            <a href="/admin/posts/edit" class="bg-[#f2cf19] hover:bg-yellow-500 text-black font-semibold py-2 px-4 rounded shadow">
                + Thêm mới
            </a>
        </div>
    </div>



    <!-- Search Form -->
    <form class="mb-6 flex gap-2 max-w-md" method="GET" action="/admin/posts">
        <input type="text" name="s" value={search} placeholder="Tìm kiếm theo tiêu đề..." class="flex-1 rounded-md border-gray-300 shadow-sm focus:border-[#f2cf19] focus:ring-[#f2cf19] px-4 py-2 border" />
        <button type="submit" class="bg-gray-800 text-white px-4 py-2 rounded-md hover:bg-gray-700">Tìm</button>
        {search && <a href="/admin/posts" class="text-gray-500 px-4 py-2 hover:text-gray-700">Xóa</a>}
    </form>

    <!-- Table -->
    <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tiêu đề</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Slug</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ngày tạo</th>
                        <th scope="col" class="relative px-6 py-3"><span class="sr-only">Hành động</span></th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {posts.length > 0 ? posts.map((post) => (
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">#{post.id}</td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-medium text-gray-900 max-w-xs truncate" title={post.title}>{post.title}</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                {post.slug}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                {new Date(post.createdAt).toLocaleDateString('vi-VN')}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <a href={`/admin/posts/edit?id=${post.id}`} class="text-[#f2cf19] hover:text-yellow-600 mr-4">Sửa</a>
                                <button class="text-red-600 hover:text-red-900 btn-delete" data-id={post.id} data-title={post.title}>Xóa</button>
                            </td>
                        </tr>
                    )) : (
                        <tr>
                            <td colspan="5" class="px-6 py-8 text-center text-gray-500">Không tìm thấy dữ liệu nào.</td>
                        </tr>
                    )}
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        {totalPages > 1 && (
            <div class="bg-white px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6">
                <div class="flex-1 flex justify-between sm:hidden">
                    <a href={`/admin/posts?s=${search}&page=${page > 1 ? page - 1 : 1}`} class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">Trước</a>
                    <a href={`/admin/posts?s=${search}&page=${page < totalPages ? page + 1 : totalPages}`} class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">Sau</a>
                </div>
                <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                    <div>
                        <p class="text-sm text-gray-700">
                            Hiển thị từ <span class="font-medium">{offset + 1}</span> đến <span class="font-medium">{Math.min(offset + perPage, total)}</span> trong tổng số <span class="font-medium">{total}</span>
                        </p>
                    </div>
                    <div>
                        <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                            {page > 1 && (
                                <a href={`/admin/posts?s=${search}&page=${page - 1}`} class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                    <span class="sr-only">Previous</span>
                                    &laquo;
                                </a>
                            )}
                            
                            {[...Array(totalPages)].map((_, i) => (
                                <a href={`/admin/posts?s=${search}&page=${i + 1}`} class={`relative inline-flex items-center px-4 py-2 border text-sm font-medium ${page === i + 1 ? 'z-10 bg-[#f2cf19] border-[#f2cf19] text-black' : 'bg-white border-gray-300 text-gray-500 hover:bg-gray-50'}`}>
                                    {i + 1}
                                </a>
                            ))}

                            {page < totalPages && (
                                <a href={`/admin/posts?s=${search}&page=${page + 1}`} class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                    <span class="sr-only">Next</span>
                                    &raquo;
                                </a>
                            )}
                        </nav>
                    </div>
                </div>
            </div>
        )}
    </div>

    <script>
        const deleteButtons = document.querySelectorAll('.btn-delete');
        deleteButtons.forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const id = (e.target as HTMLElement).getAttribute('data-id');
                const title = (e.target as HTMLElement).getAttribute('data-title');
                
                if (confirm(`Bạn có chắc chắn muốn xóa "${title}" không? Hành động này không thể hoàn tác!`)) {
                    try {
                        const res = await fetch(`/api/admin/posts/${id}`, {
                            method: 'DELETE',
                        });
                        if (res.ok) {
                            window.location.reload();
                        } else {
                            alert('Xóa thất bại!');
                        }
                    } catch (err) {
                        console.error(err);
                        alert('Có lỗi xảy ra!');
                    }
                }
            });
        });
    </script>
</AdminLayout>
