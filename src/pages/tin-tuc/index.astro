---
import Layout from '../../layouts/Layout.astro';

import { env } from 'cloudflare:workers';

export const prerender = false;

let posts = [];

try {
    const db = (env as any)?.DB || (env as any)?.hethongbiatuoi_db;
    if (db) {
        const { results } = await db.prepare(`
            SELECT p.id, p.title, p.slug, p.excerpt, p.createdAt, m.url as imageUrl 
            FROM Post p
            LEFT JOIN Media m ON p.featuredImage = m.id
            WHERE p.type = 'post'
            ORDER BY p.createdAt DESC 
        `).all();
        posts = (results || []).map((p: any) => {
            if (p.imageUrl && !p.imageUrl.includes('/proxy-cors/')) {
                p.imageUrl = p.imageUrl.replace(/(?:https?:\/\/hethongbiatuoi\.com)?\/?wp-content/gi, '/proxy-cors/wp-content');
            }
            if (p.excerpt && !p.excerpt.includes('/proxy-cors/')) {
                p.excerpt = p.excerpt.replace(/(?:https?:\/\/hethongbiatuoi\.com)?\/?wp-content/gi, '/proxy-cors/wp-content');
            }
            return p;
        });
    }
} catch (e) {
    console.log("DB Error:", e);
}
---

<Layout title="Tin Tức | Hệ Thống Bia Tươi">
    <div class="bg-slate-900 py-16">
        <div class="container mx-auto px-4 text-center">
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Tin Tức & Sự Kiện</h1>
            <p class="text-slate-400 text-lg">Cập nhật tin tức mới nhất, sự kiện ưu đãi và kiến thức bia tươi.</p>
        </div>
    </div>

    <section class="py-16 bg-slate-50 min-h-screen">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
                {posts.map((post: any) => {
                    const dateObj = new Date(post.createdAt);
                    const formattedDate = dateObj.toLocaleDateString('vi-VN', {
                        year: 'numeric', month: 'long', day: 'numeric'
                    });
                    
                    return (
                    <article class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-shadow duration-300 overflow-hidden flex flex-col group">
                        <a href={`/${post.slug}`} class="block overflow-hidden aspect-[16/10]">
                            {post.imageUrl ? (
                                <img 
                                    src={post.imageUrl} 
                                    alt={post.title} 
                                    class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
                                />
                            ) : (
                                <div class="w-full h-full bg-slate-200 flex items-center justify-center">
                                    <span class="text-slate-400">No Image</span>
                                </div>
                            )}
                        </a>
                        <div class="p-6 flex flex-col flex-grow">
                            <time class="text-xs font-semibold text-brand-500 mb-2 block uppercase tracking-wider">{formattedDate}</time>
                            <h3 class="text-xl font-bold text-slate-900 mb-3 line-clamp-2">
                                <a href={`/${post.slug}`} class="hover:text-brand-600 transition-colors" set:html={post.title}></a>
                            </h3>
                            <div class="text-slate-600 text-sm line-clamp-3 mb-6 flex-grow" set:html={post.excerpt} />
                            <a href={`/${post.slug}`} class="text-slate-900 font-bold hover:text-brand-600 transition-colors text-sm uppercase tracking-wider inline-flex items-center group-hover:translate-x-1 duration-300">
                                Đọc tiếp <span class="ml-2">&rarr;</span>
                            </a>
                        </div>
                    </article>
                )})}
            </div>
            
            {posts.length === 0 && (
                <div class="text-center text-slate-500 py-20">Chưa có bài viết nào.</div>
            )}
        </div>
    </section>
</Layout>
