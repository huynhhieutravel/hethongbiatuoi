---
import NativeLayout from '../layouts/NativeLayout.astro';
---

<NativeLayout title="Liên Hệ - Hệ Thống Bia Tháp Vina Sài Gòn">
    <div class="bg-white min-h-screen pt-24 pb-32">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <!-- Minimal Hero -->
            <div class="max-w-3xl mx-auto mb-20">
                <h1 class="text-4xl md:text-5xl font-bold text-zinc-900 tracking-tight mb-6">Liên Hệ</h1>
                <p class="text-xl text-zinc-500 font-light leading-relaxed">
                    Đội ngũ của chúng tôi luôn sẵn sàng hỗ trợ bạn. Vui lòng liên hệ trực tiếp qua các thông tin bên dưới để được phục vụ nhanh nhất.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-16 mb-32">
                
                <!-- Item 1: Hotline -->
                <div class="flex flex-col items-center justify-center p-8 group">
                    <div class="w-20 h-20 bg-zinc-50 rounded-[1.5rem] flex items-center justify-center mb-8 border border-zinc-100 group-hover:bg-zinc-900 group-hover:border-zinc-900 group-hover:-translate-y-2 transition-all duration-300">
                        <i class="fas fa-phone-alt text-2xl text-zinc-800 group-hover:text-white transition-colors duration-300"></i>
                    </div>
                    <h3 class="text-sm font-semibold text-zinc-900 uppercase tracking-widest mb-4">Hotline</h3>
                    <a href="tel:0963447890" class="text-3xl lg:text-4xl font-light text-zinc-600 hover:text-zinc-900 transition-colors">
                        0963 447 890
                    </a>
                </div>
                
                <!-- Item 2: Facebook -->
                <div class="flex flex-col items-center justify-center p-8 group">
                    <div class="w-20 h-20 bg-zinc-50 rounded-[1.5rem] flex items-center justify-center mb-8 border border-zinc-100 group-hover:bg-[#1877F2] group-hover:border-[#1877F2] group-hover:-translate-y-2 transition-all duration-300">
                        <i class="fab fa-facebook-f text-3xl text-zinc-800 group-hover:text-white transition-colors duration-300"></i>
                    </div>
                    <h3 class="text-sm font-semibold text-zinc-900 uppercase tracking-widest mb-4">Facebook</h3>
                    <a href="https://fb.com/hethongbiathap" target="_blank" class="text-2xl lg:text-3xl font-light text-zinc-600 hover:text-[#1877F2] transition-colors">
                        Hệ Thống Bia Tháp
                    </a>
                </div>

                <!-- Item 3: Address -->
                <div class="flex flex-col items-center justify-center p-8 group">
                    <div class="w-20 h-20 bg-zinc-50 rounded-[1.5rem] flex items-center justify-center mb-8 border border-zinc-100 group-hover:bg-red-600 group-hover:border-red-600 group-hover:-translate-y-2 transition-all duration-300">
                        <i class="fas fa-map-marker-alt text-3xl text-zinc-800 group-hover:text-white transition-colors duration-300"></i>
                    </div>
                    <h3 class="text-sm font-semibold text-zinc-900 uppercase tracking-widest mb-4">Trụ Sở</h3>
                    <p class="text-xl lg:text-2xl font-light text-zinc-600 leading-relaxed text-center group-hover:text-zinc-900 transition-colors">
                        Ấp 1B, Thuận An<br>
                        <span class="text-base text-zinc-400">Bình Dương, Việt Nam</span>
                    </p>
                </div>

            </div>

            <!-- Fullwidth Map Minimal -->
            <div class="text-left">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-2xl font-bold text-zinc-900">Bản Đồ</h3>
                    <a href="https://www.google.com/maps/place/H%E1%BB%87+Th%E1%BB%91ng+Bia+Th%C3%A1p+-+Bia+T%C6%B0%C6%A1i+-+Bia+Inox/@10.9590431,106.7286367,14z/" target="_blank" class="text-sm font-medium text-zinc-500 hover:text-zinc-900 transition-colors uppercase tracking-widest">
                        Mở trong Google Maps &rarr;
                    </a>
                </div>
                <div class="h-[500px] w-full rounded-2xl overflow-hidden bg-zinc-100 border border-zinc-200">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d33199.82086797063!2d106.7286367030436!3d10.959043107938827!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3174d9f00f181261%3A0xc065bf7e1f7a19ae!2zSOG7hyBUaOG7kW5nIEJpYSBUaMOhcCAtIEJpYSBUxrDGoWkgLSBCaWEgSW5veA!5e0!3m2!1sen!2s!4v1622018496322!5m2!1sen!2s" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" class="w-full h-full filter grayscale-[50%] contrast-[95%] opacity-90 hover:grayscale-0 hover:opacity-100 transition-all duration-700"></iframe>
                </div>
            </div>
        </div>
    </div>
</NativeLayout>
