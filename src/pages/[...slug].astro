    transition: color 0.2s;
}
.custom-breadcrumb a:hover {
    color: #ffcc00;
}
.custom-breadcrumb .separator {
    color: #999;
}
.custom-breadcrumb .current {
    color: #999;
}

.custom-share-buttons {
    display: flex;
    gap: 15px;
    margin-bottom: 25px;
}
.custom-share-buttons .share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    border-radius: 4px;
    font-weight: bold;
    text-decoration: none;
    cursor: pointer;
    border: none;
    font-size: 14px;
    transition: background-color 0.2s;
}
.custom-share-buttons .fb {
    background-color: #1877F2;
    color: white;
}
.custom-share-buttons .fb:hover {
    background-color: #166FE5;
}
.custom-share-buttons .copy {
    background-color: #f1f1f1;
    color: #333;
}
.custom-share-buttons .copy:hover {
    background-color: #e4e4e4;
}

.custom-related-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin: 0 auto 40px auto;
    max-width: 1140px;
    padding: 0 10px;
    justify-content: flex-start;
}
.custom-related-btn {
    background-color: #000;
    color: #ffcc00;
    border-radius: 50px;
    padding: 10px 25px;
    font-weight: bold;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-block;
    text-align: center;
}
.custom-related-btn:hover {
    background-color: #ffcc00;
    color: #000;
}

/* Custom Hotline CTA */
.custom-hotline-cta {
