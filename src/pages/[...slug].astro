---
import Layout from '../layouts/Layout.astro';
import ArchiveCTA from '../components/ArchiveCTA.astro';
import { env } from 'cloudflare:workers';
import * as cheerio from 'cheerio';

export const prerender = false;

const { slug } = Astro.params;
console.log("=> HIT [...slug].astro WITH SLUG:", slug);

// Extract the last segment of the slug
const paths = (slug || '').split('/').filter(Boolean);
const lastSegment = paths[paths.length - 1] || slug;

let post = null;
let category = null;
let categoryPosts = [];

try {
    const db = (env as any)?.DB || (env as any)?.hethongbiatuoi_db;
    if (db) {
        let prefix = paths.length > 1 ? paths[0] : '';
        let matched = false;

        const processCategoryPosts = (results: any) => {
            if (!results) return [];
            return results.map((p: any) => {
                if (p.imageUrl && !p.imageUrl.includes('/proxy-cors/')) {
                    p.imageUrl = p.imageUrl.replace(/(?:https?:\/\/hethongbiatuoi\.com)?\/?wp-content/gi, '/proxy-cors/wp-content');
                }
                return p;
            });
        };

        if (prefix === 'tag') {
            let stmt = await db.prepare("SELECT * FROM Tag WHERE slug = ? LIMIT 1").bind(lastSegment).first();
            if (stmt) {
                category = stmt;
                const { results } = await db.prepare(`
                    SELECT p.id, p.title, p.slug, p.createdAt, m.url as imageUrl FROM Post p 
                    JOIN PostTag pt ON p.id = pt.postId 
                    LEFT JOIN Media m ON p.featuredImage = m.id
                    WHERE pt.tagId = ?
                    UNION ALL
                    SELECT p.id, p.title, p.slug, p.createdAt, m.url as imageUrl FROM Product p 
                    JOIN ProductTag pt ON p.id = pt.productId 
                    LEFT JOIN Media m ON p.featuredImage = m.id
                    WHERE pt.tagId = ?
                    ORDER BY 4 DESC
                `).bind(category.id, category.id).all();
                categoryPosts = processCategoryPosts(results);
                matched = true;
            }
        } else if (prefix === 'san-pham' || prefix === 'danh-muc' || prefix === 'category') {
            let stmt = await db.prepare("SELECT * FROM Category WHERE slug = ? LIMIT 1").bind(lastSegment).first();
            if (stmt) {
                category = stmt;
                const { results } = await db.prepare(`
                    SELECT p.id, p.title, p.slug, p.createdAt, m.url as imageUrl FROM Post p 
                    JOIN PostCategory pc ON p.id = pc.postId 
                    LEFT JOIN Media m ON p.featuredImage = m.id
                    WHERE pc.categoryId = ?
                    UNION ALL
                    SELECT p.id, p.title, p.slug, p.createdAt, m.url as imageUrl FROM Product p 
                    JOIN ProductCategory pc ON p.id = pc.productId 
                    LEFT JOIN Media m ON p.featuredImage = m.id
                    WHERE pc.categoryId = ?
                    ORDER BY 4 DESC
                `).bind(category.id, category.id).all();
                categoryPosts = processCategoryPosts(results);
                matched = true;
            }
        }

        // If no strict prefix matched, OR it didn't have a prefix, fallback to the old logic
        if (!matched) {
            let stmt = await db.prepare(`
                SELECT p.*, 'post' as entityType, m.url as imageUrl 
                FROM Post p 
                LEFT JOIN Media m ON p.featuredImage = m.id
                WHERE p.slug = ? LIMIT 1
            `).bind(lastSegment).first();
            
            if (!stmt) {
                stmt = await db.prepare(`
                    SELECT p.*, 'product' as entityType, m.url as imageUrl 
                    FROM Product p 
                    LEFT JOIN Media m ON p.featuredImage = m.id
                    WHERE p.slug = ? LIMIT 1
                `).bind(lastSegment).first();
            }

            if (stmt) {
                post = stmt;
                if (post.content) {
                    // Strip WP dimensions from images to prevent 404s
                    post.content = post.content.replace(/-\d+x\d+\.(jpg|jpeg|png|webp|gif)/gi, '.$1');
                    // Point uploads to R2 and strip YYYY/MM/
                    post.content = post.content.replace(/(src=|href=|srcset=|url\()(["']?)(?:https?:\/\/(?:www\.)?hethongbiatuoi\.com)?\/?wp-content\/uploads\/(?:\d{4}\/\d{2}\/)?([^\s"'>)]+)/gi, '$1$2https://media.hethongbiatuoi.com/$3');
                    // Point other wp-content (CSS/JS) to proxy-cors
                    post.content = post.content.replace(/(src=|href=|srcset=|url\()(["']?)(?:https?:\/\/(?:www\.)?hethongbiatuoi\.com)?\/?(wp-content\/(?!uploads\/))/gi, '$1$2/proxy-cors/$3');
                    // Remove Elementor entrance animations that hide text since JS is removed
                    post.content = post.content.replace(/elementor-invisible/g, '');
                    // Fix broken goqr.me error text saved in DB
                    post.content = post.content.replace(
                        /en:\s*malformed\s*'create-qr-code'\s*API\s*request[^<]*/gi,
                        `<img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://hethongbiatuoi.com/${post.slug}/" alt="QR Code" width="100" height="100" style="display:inline-block; vertical-align:middle; margin-left: 10px;" />`
                    );

                    try {
                        const $ = cheerio.load(post.content);
                        
                        // Rewrite Breadcrumbs
                        const breadcrumbWidget = $('.elementor-widget-post-info').first();
                        if (breadcrumbWidget.length > 0) {
                            breadcrumbWidget.replaceWith(`
                                <nav class="custom-breadcrumb" aria-label="Breadcrumb">
                                    <a href="/">Trang chủ</a>
                                    <span class="separator">/</span>
                                    <a href="/san-pham/">Sản Phẩm</a>
                                    <span class="separator">/</span>
                                    <span class="current" aria-current="page">${post.title}</span>
                                </nav>
                            `);
                        }

                        // Rewrite Share Buttons
                        $('.elementor-widget-share-buttons').replaceWith(`
                            <div class="custom-share-buttons">
                                <a href="https://www.facebook.com/sharer/sharer.php?u=https://hethongbiatuoi.com/${post.slug}/" target="_blank" class="share-btn fb">Facebook</a>
                                <button type="button" onclick="navigator.clipboard.writeText('https://hethongbiatuoi.com/${post.slug}/'); alert('Đã copy link sản phẩm!');" class="share-btn copy">Copy Link</button>
                            </div>
                        `);

                        // Rewrite "Xem thêm" tags grid
                        const relatedTags: string[] = [];
                        $('.elementor-widget-button a.elementor-button').each((_, el) => {
                            const text = $(el).text().trim();
                            const href = $(el).attr('href') || '#';
                            relatedTags.push(`<a href="${href}" class="custom-related-btn">${text}</a>`);
                        });

                        if (relatedTags.length > 0) {
                            // Find the heading section to insert after
                            const xemThemHeading = $('h2.elementor-heading-title').filter(function() {
                                return $(this).text().trim().includes('Xem thêm');
                            }).closest('.elementor-section');

                            if (xemThemHeading.length > 0) {
                                xemThemHeading.after(`
                                    <div class="custom-related-tags">
                                        ${relatedTags.join('')}
                                    </div>
                                `);
                            }

                            // Remove the old button sections
                            $('.elementor-section').each((_, el) => {
                                if ($(el).find('.elementor-widget-button').length > 0) {
                                    $(el).remove();
                                }
                            });
                        }

                        // Rewrite Hotline CTA
                        const hotlineSection = $('.elementor-section').filter(function() {
                            return $(this).text().includes('Hotline Đặt Bia') && $(this).text().includes('0963');
                        });
                        
                        if (hotlineSection.length > 0) {
                            hotlineSection.replaceWith(`
                                <div class="custom-hotline-cta">
                                    <div class="hotline-icon">📞</div>
                                    <div class="hotline-text">
                                        <div class="hotline-title">Hotline Đặt Bia Tươi ngay</div>
                                        <a href="tel:0963447890" class="hotline-number">0963 447 890</a>
                                    </div>
                                </div>
                            `);
                        }

                        post.content = $.html();
                    } catch (e) {
                        console.error('Cheerio processing error:', e);
                    }
                }
            } else {
                // fallback to category/tag if still not found (e.g. they removed the prefix)
                stmt = await db.prepare("SELECT * FROM Category WHERE slug = ? LIMIT 1").bind(lastSegment).first();
                if (stmt) {
                    category = stmt;
                    const { results } = await db.prepare(`
                        SELECT p.id, p.title, p.slug, p.createdAt, m.url as imageUrl FROM Post p 
                        JOIN PostCategory pc ON p.id = pc.postId 
                        LEFT JOIN Media m ON p.featuredImage = m.id
                        WHERE pc.categoryId = ?
                        UNION ALL
                        SELECT p.id, p.title, p.slug, p.createdAt, m.url as imageUrl FROM Product p 
                        JOIN ProductCategory pc ON p.id = pc.productId 
                        LEFT JOIN Media m ON p.featuredImage = m.id
                        WHERE pc.categoryId = ?
                        ORDER BY 4 DESC
                    `).bind(category.id, category.id).all();
                    categoryPosts = processCategoryPosts(results);
                    console.log("Found category:", category.name, "Posts:", categoryPosts.length);
                } else {
                    stmt = await db.prepare("SELECT * FROM Tag WHERE slug = ? LIMIT 1").bind(lastSegment).first();
                    if (stmt) {
                        category = stmt;
                        const { results } = await db.prepare(`
                            SELECT p.id, p.title, p.slug, p.createdAt, m.url as imageUrl FROM Post p 
                            JOIN PostTag pt ON p.id = pt.postId 
                            LEFT JOIN Media m ON p.featuredImage = m.id
                            WHERE pt.tagId = ?
                            UNION ALL
                            SELECT p.id, p.title, p.slug, p.createdAt, m.url as imageUrl FROM Product p 
                            JOIN ProductTag pt ON p.id = pt.productId 
                            LEFT JOIN Media m ON p.featuredImage = m.id
                            WHERE pt.tagId = ?
                            ORDER BY 4 DESC
                        `).bind(category.id, category.id).all();
                        categoryPosts = processCategoryPosts(results);
                        console.log("Found tag:", category.name, "Posts:", categoryPosts.length);
                    }
                }
            }
        }
    }
} catch (e) {
    console.log("DB Error in [...slug].astro:", e);
}

if (!post && !category) {
    return Astro.redirect('/404');
}

// Function to extract volume (e.g. 900ml) from title for the yellow badge
const extractVolume = (title) => {
    const match = title.match(/(\d+ml)/i);
    return match ? `bia ${match[1].toLowerCase()}` : '';
};

// Hardcoded categories list from screenshot for the pill buttons
const catLinks = [
    { name: "Bia Tháp", slug: "bia-thap" },
    { name: "Bia Tươi", slug: "bia-tuoi" },
    { name: "Bia Inox", slug: "bia-inox" },
    { name: "Bến Thành Sài Gòn", slug: "bia-ben-thanh-sai-gon" },
    { name: "Vina Sài Gòn", slug: "bia-vina-sai-gon" },
    { name: "Hemsi Sài Gòn", slug: "bia-hemsi-sai-gon" },
    { name: "Naviken", slug: "bia-naviken" },
    { name: "Bia Craft", slug: "bia-craft" }
];
---

<Layout title={post ? post.title : category?.name}>
    {post ? (
        <>
            <link rel="stylesheet" href={`/proxy-cors/wp-content/uploads/elementor/css/post-${post.id}.css`} media="all" />
            <Fragment set:html={post.content} />
        </>
    ) : (
        <div class="category-archive-wrapper">
            
            {/* Elementor-style Banner */}
            <div class="cat-banner">
                <div class="cat-banner-overlay"></div>
                <div class="cat-banner-content">
                    <h1 set:html={category.name}></h1>
                    <p>Bia Của Người Sành Điệu</p>
                </div>
            </div>

            <div class="category-archive-container">
                
                {/* Pill Buttons Navigation */}
                <div class="cat-nav-pills">
                    {catLinks.map(link => (
                        <a href={`/tag/${link.slug}/`} class="cat-pill">{link.name}</a>
                    ))}
                </div>
                
                {/* Product Grid */}
                {categoryPosts.length > 0 ? (
                    <div class="products-grid">
                        {categoryPosts.map((p) => {
                            let imgSrc = p.imageUrl || '';
                            let badgeText = extractVolume(p.title);
                            return (
                            <div class="product-card">
                                <a href={`/${p.slug}`}>
                                    <div class="product-image">
                                        {badgeText && <span class="product-badge">{badgeText}</span>}
                                        {imgSrc ? (
                                            <img src={imgSrc} alt={p.title} loading="lazy" />
                                        ) : (
                                            <div class="product-image-placeholder">No Image</div>
                                        )}
                                    </div>
                                    <div class="product-info">
                                        <h3 class="product-title" set:html={p.title}></h3>
                                        <div class="product-details-text">CHI TIẾT SẢN PHẨM</div>
                                    </div>
                                    <div class="product-footer">
                                        hethongbiathap
                                    </div>
                                </a>
                            </div>
                        )})}
                    </div>
                ) : (
                    <div class="no-products-container">
                        <p class="no-products">Chưa có sản phẩm nào trong danh mục này.</p>
                    </div>
                )}
            </div>

            {/* Original Elementor CTA Block */}
            <ArchiveCTA />
            
        </div>
    )}
</Layout>

<style is:global>
/* ELEMENTOR POLYFILL FOR PRODUCTS */
.elementor-container {
    display: flex;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
}
.elementor-column {
    padding: 15px;
    box-sizing: border-box;
}
.elementor-col-50 {
    width: 50%;
}
.elementor-col-100 {
    width: 100%;
}
.elementor-col-33 {
    width: 33.333%;
}
.elementor-col-25 {
    width: 25%;
}
@media (max-width: 768px) {
    .elementor-col-50, .elementor-col-33, .elementor-col-25 {
        width: 100%;
    }
}
.elementor-widget-heading h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #111;
    margin-bottom: 15px;
}
.elementor-widget-heading h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #222;
    margin: 30px 0 15px;
}
.elementor-widget-text-editor {
    line-height: 1.8;
    color: #444;
    font-size: 16px;
}
.elementor-star-rating {
    color: #ffcc00;
    font-size: 1.2rem;
    margin-bottom: 20px;
    font-family: Arial, sans-serif;
    display: flex;
    align-items: center;
    gap: 8px;
}
.elementor-star-full {
    display: inline-block;
    width: 20px;
    height: 20px;
    background-color: #ffcc00;
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}
.elementor-star-7 {
    display: inline-block;
    width: 20px;
    height: 20px;
    background: linear-gradient(to right, #ffcc00 70%, #ccc 30%);
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}
.elementor-star-rating i {
    color: transparent;
}
.elementor-share-buttons--view-icon .elementor-grid {
    display: flex;
    gap: 15px;
    align-items: center;
    margin-bottom: 20px;
}
.elementor-share-buttons--view-icon .elementor-share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    color: white;
    text-decoration: none;
    position: relative;
}
/* Fallback icons using CSS pseudo-elements since FontAwesome is broken */
.elementor-share-btn_facebook::after { content: "f"; font-weight: bold; font-family: sans-serif; font-size: 20px; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }
.elementor-share-btn_twitter::after { content: "t"; font-weight: bold; font-family: sans-serif; font-size: 20px; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }
.elementor-share-btn_telegram::after { content: "tg"; font-weight: bold; font-family: sans-serif; font-size: 18px; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); }
.elementor-share-btn_facebook .elementor-share-btn__icon,
.elementor-share-btn_twitter .elementor-share-btn__icon,
.elementor-share-btn_telegram .elementor-share-btn__icon {
    display: none;
}
.elementor-share-btn_facebook { background: #3b5998; }
.elementor-share-btn_twitter { background: #1da1f2; }
.elementor-share-btn_telegram { background: #0088cc; }
.elementor-posts-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
}
.elementor-post__thumbnail img {
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 1;
    border-radius: 8px;
}
.elementor-post__title {
    font-size: 1.1rem;
    margin-top: 10px;
}
.elementor-post__title a {
    color: #111;
    text-decoration: none;
}
.elementor-post__read-more {
    color: #ffcc00;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 0.85rem;
    text-decoration: none;
}
.swiper-slide-image {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}
.elementor-section-boxed {
    padding: 20px 0;
}
.elementor-post-info__terms-list {
    display: block;
    line-height: 2.5;
    font-size: 0; /* Hide the commas */
}
.elementor-post-info__terms-list-item {
    background: #f1f1f1;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 14px; /* Restore font size for tags */
