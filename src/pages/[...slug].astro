    display: inline-block;
    margin-right: 8px;
    font-weight: 500;
}
.elementor-post-info__item-prefix {
    font-size: 15px;
    margin-right: 5px;
    font-weight: bold;
}
.elementor-widget-jet-listing-dynamic-field {
    margin-bottom: 25px;
}
/* Style the buttons grid at the bottom */
.elementor-section:has(.elementor-widget-button) .elementor-container {
    justify-content: center;
    gap: 15px;
}
.elementor-section:has(.elementor-widget-button) .elementor-column {
    width: auto !important;
    padding: 5px !important;
}
.elementor-button {
    background-color: #000 !important;
    color: #ffcc00 !important;
    border-radius: 50px !important;
    padding: 10px 25px !important;
    font-weight: bold !important;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    min-width: 140px;
}
.elementor-button:hover {
    background-color: #ffcc00 !important;
    color: #000 !important;
}

/* Recreating the Elementor Live Site Design */
.category-archive-wrapper {
    background-color: #ffffcc; /* Pale yellow from screenshot */
    min-height: 100vh;
    font-family: Arial, sans-serif;
}

/* Banner */
.cat-banner {
    position: relative;
    width: 100%;
    height: 400px;
    background-image: linear-gradient(rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.35)), url('https://media.hethongbiatuoi.com/san-pham-he-thong-bia-thap.webp');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    padding-left: 10%;
}
.cat-banner-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
}
.cat-banner-content {
    position: relative;
    z-index: 2;
    color: #fff;
}
.cat-banner-content h1 {
    font-size: 80px;
    margin: 0 0 10px 0;
