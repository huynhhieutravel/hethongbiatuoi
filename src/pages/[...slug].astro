    text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
}
.cat-banner-content p {
    font-size: 24px;
    margin: 0;
}

/* FIX ELEMENTOR CATEGORY BUTTONS GRID */
.elementor-widget-button:not([data-id="7c769661"]) .elementor-button {
    background-color: #000 !important;
    color: #ffcc00 !important;
    border-radius: 50px !important;
    padding: 10px 25px !important;
    font-weight: bold !important;
    transition: all 0.3s ease;
}
.elementor-widget-button:not([data-id="7c769661"]) .elementor-button:hover {
    background-color: #ffcc00 !important;
    color: #000 !important;
}

@media (max-width: 768px) {
    /* Only target sections that contain MULTIPLE buttons (the category list) or target by avoiding the Archive CTA */
    /* Archive CTA has class elementor-section-height-min-height, so we avoid it */
    .elementor-section:not(.elementor-section-height-min-height):has(.elementor-widget-button) > .elementor-container {
        display: flex !important;
        flex-wrap: wrap !important;
        justify-content: center !important;
        gap: 10px !important;
    }
    .elementor-section:not(.elementor-section-height-min-height):has(.elementor-widget-button) .elementor-column {
        width: auto !important;
        flex: 0 0 auto !important;
        margin-bottom: 0 !important;
    }
    .elementor-widget-button {
        width: auto !important;
    }
    .elementor-widget-button .elementor-button {
        padding: 8px 16px !important;
        font-size: 13px !important;
    }
    .elementor-column.elementor-hidden-phone {
        display: none !important;
    }
}

/* Container */
.category-archive-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
}
.category-archive-wrapper p {
    margin-bottom: 10px;
}
.category-archive-wrapper ul {
    list-style-type: disc;
    margin-left: 20px;
    margin-bottom: 20px;
}

/* Custom Rewritten Blocks */
.custom-breadcrumb {
    font-size: 14px;
    color: #666;
    margin-bottom: 25px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}
.custom-breadcrumb a {
